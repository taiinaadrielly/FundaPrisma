generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mysql"
    url  = env("DATABASE_URL")
}

enum Role {
    USER
    ADMIN
}

//Comando: npx prisma db push - para criar a tabela no banco de dados
model user {
    id          Int         @id @default(autoincrement())
    name        String
    email       String      @unique
    status      Boolean     @default(true)
    role        Role        @default(USER)
    createdAt   DateTime    @default(now())
    updatedAt   DateTime    @updatedAt
    posts       Post[]

    @@map("users") //Mapeia a tabela para users no banco
}

model Post {
    id Int @id @default(autoincrement())
    title String
    subtitle String?
    content String
    userId Int @map("user_id")
    User user @relation(fields:[userId], references: [id])

    @@map("posts") //Mapeia a tabela para users no banco
}